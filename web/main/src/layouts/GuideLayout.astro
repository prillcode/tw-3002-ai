---
import Layout from './Layout.astro';
import TerminalHeader from '../components/TerminalHeader.vue';
const { frontmatter } = Astro.props;
---
<Layout title={`${frontmatter.title} — TW 3002 AI Guide`} description={frontmatter.description}>
  <TerminalHeader client:load />
  <div class="max-w-6xl mx-auto px-4 py-8 flex gap-8">
    <!-- Sidebar -->
    <aside class="hidden md:block w-64 shrink-0">
      <nav class="sticky top-4">
        <p class="text-xs font-mono text-terminal-muted uppercase tracking-wider mb-4">Guide</p>
        <ul class="space-y-2">
          <li><a href="/guide/getting-started" class="text-sm font-mono hover:text-terminal-cyan transition-colors">Getting Started</a></li>
          <li><a href="/guide/trading" class="text-sm font-mono hover:text-terminal-cyan transition-colors">Trading</a></li>
          <li><a href="/guide/combat" class="text-sm font-mono hover:text-terminal-cyan transition-colors">Combat</a></li>
          <li><a href="/guide/stardock" class="text-sm font-mono hover:text-terminal-cyan transition-colors">StarDock & Upgrades</a></li>
          <li><a href="/guide/keyboard" class="text-sm font-mono hover:text-terminal-cyan transition-colors">Keyboard Reference</a></li>
        </ul>
      </nav>
    </aside>
    <!-- Content -->
    <article class="flex-1 min-w-0">
      <div class="prose prose-invert prose-cyan max-w-none">
        <slot />
      </div>
    </article>
  </div>
</Layout>
