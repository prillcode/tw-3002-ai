---
import { getCollection } from 'astro:content';
import Layout from './Layout.astro';
import TerminalHeader from '../components/TerminalHeader.vue';
const { frontmatter } = Astro.props;

const guides = await getCollection('guide');
guides.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---
<Layout title={`${frontmatter.title} — TW 3002 AI Guide`} description={frontmatter.description}>
  <TerminalHeader client:load />
  <div class="max-w-6xl mx-auto px-4 py-8 flex gap-8">
    <!-- Sidebar -->
    <aside class="hidden md:block w-64 shrink-0">
      <nav class="sticky top-4">
        <p class="text-xs font-mono text-terminal-muted uppercase tracking-wider mb-4">Guide</p>
        <ul class="space-y-2">
          {guides.map((guide) => (
            <li>
              <a href={`/guide/${guide.slug}`} class="text-sm font-mono hover:text-terminal-cyan transition-colors">
                {guide.data.title}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
    <!-- Content -->
    <article class="flex-1 min-w-0">
      <div class="prose prose-invert prose-cyan max-w-none">
        <slot />
      </div>
    </article>
  </div>
</Layout>
