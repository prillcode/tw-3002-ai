---
import Layout from '../../layouts/Layout.astro';
const specUrl = new URL('/openapi.yaml', Astro.url.origin).href;
---

<Layout title="API Reference — TW 3002 AI">
  <div style="height: 100vh; width: 100vw;">
    <script
      is:inline
      id="api-reference"
      data-url={specUrl}
      data-theme="deepSpace"
      data-hide-download-button="true"
      type="module"
      src="https://cdn.jsdelivr.net/npm/@scalar/api-reference"
    ></script>
  </div>
</Layout>
